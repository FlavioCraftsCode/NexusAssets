@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="flex h-screen bg-slate-50 font-sans antialiased text-slate-900">
    <aside class="w-64 bg-white border-r border-slate-200 flex-shrink-0 flex flex-col shadow-sm">
        <div class="p-6 border-b border-slate-100">
            <h2 class="text-xl font-bold tracking-tight flex items-center gap-2">
                <span class="p-2 bg-indigo-600 rounded-lg text-white text-xs">NA</span>
                NexusAssets
            </h2>
        </div>
        <nav class="flex-1 p-4 space-y-2">
            <NavLink href="/" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-600 hover:bg-slate-50 transition-all font-medium">
                 Home
            </NavLink>
            <NavLink href="assets" class="flex items-center gap-3 px-4 py-2.5 rounded-xl bg-indigo-50 text-indigo-700 font-bold shadow-sm shadow-indigo-100/50">
                 Ativos
            </NavLink>
            <NavLink href="reports" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-600 hover:bg-slate-50 transition-all font-medium">
                 Relatórios
            </NavLink>
        </nav>
        <div class="p-4 border-t border-slate-100 text-xs text-slate-400 font-medium">
            v1.0.0-Beta • Clean Arch
        </div>
    </aside>

    <main class="flex-1 overflow-y-auto scroll-smooth">
        <header class="h-16 bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-10 flex items-center justify-between px-8">
            <span class="text-sm font-semibold text-slate-500 uppercase tracking-widest">Dashboard de Operações</span>
            <div class="flex items-center gap-4">
                <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center text-xs font-bold">JD</div>
            </div>
        </header>
        
        <div class="p-8">
            
            @Body
        </div>
    </main>
</div>
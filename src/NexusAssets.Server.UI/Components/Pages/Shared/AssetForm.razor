@using NexusAssets.Domain.Entities
@using NexusAssets.Application.Common.Interfaces
@inject IAssetService AssetService

<div class="bg-white p-8 rounded-2xl shadow-xl border border-indigo-100 mb-8 animate-in fade-in slide-in-from-top-4">
    <h3 class="text-xl font-bold text-slate-800 mb-6">Registrar Novo Ativo</h3>
    
    <EditForm Model="@NovoAsset" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            
            
            <div class="flex flex-col gap-2">
                <label class="text-sm font-bold text-slate-700">Nome do Ativo</label>
                <InputText @bind-Value="NovoAsset.Name" 
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition" 
                           placeholder="Ex: Servidor Dell" />
            </div>

            
            <div class="flex flex-col gap-2">
                <label class="text-sm font-bold text-slate-700">Nº de Série</label>
                <InputText @bind-Value="NovoAsset.SerialNumber" 
                           class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition" 
                           placeholder="SN-123..." />
            </div>

            
            <div class="flex flex-col gap-2">
                <label class="text-sm font-bold text-slate-700">Valor</label>
                <InputNumber @bind-Value="NovoAsset.Value" 
                             class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 outline-none transition" />
            </div>

            
            <div class="flex flex-col gap-2">
                <label class="text-sm font-bold text-slate-700">Categoria</label>
                <MudSelect T="int?" @bind-Value="NovoAsset.CategoryId" 
                           Placeholder="Selecione a Categoria"
                           AnchorOrigin="Origin.BottomCenter" 
                           Variant="Variant.Outlined" 
                           Margin="Margin.Dense"
                           Clearable="true"
                           Class="bg-white rounded-xl">
                    <MudSelectItem T="int?" Value="null">Sem Categoria</MudSelectItem>
                    @foreach (var cat in Categories)
                    {
                        <MudSelectItem T="int?" Value="@cat.Id">@cat.Name</MudSelectItem>
                    }
                </MudSelect>
            </div>

            
            <div class="flex flex-col gap-2">
                <label class="text-sm font-bold text-slate-700">Localização</label>
                <MudSelect T="int?" @bind-Value="NovoAsset.LocationId" 
                           Placeholder="Onde está o ativo?"
                           AnchorOrigin="Origin.BottomCenter" 
                           Variant="Variant.Outlined" 
                           Margin="Margin.Dense"
                           Clearable="true"
                           Class="bg-white rounded-xl">
                    <MudSelectItem T="int?" Value="null">Sem Localização</MudSelectItem>
                    @foreach (var loc in Locations)
                    {
                        <MudSelectItem T="int?" Value="@loc.Id">@loc.Name</MudSelectItem>
                    }
                </MudSelect>
            </div>

            
            <div class="md:col-span-3 flex justify-end mt-4">
                <button type="submit" class="bg-indigo-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-indigo-700 shadow-lg transition-all active:scale-95">
                    Salvar no Patrimônio
                </button>
            </div>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public Asset NovoAsset { get; set; } = new();
    [Parameter] public EventCallback OnValidSubmit { get; set; }

    private List<Category> Categories = new();
    private List<Location> Locations = new();

    protected override async Task OnInitializedAsync()
    {
        
        Categories = await AssetService.GetCategoriesAsync();
        Locations = await AssetService.GetLocationsAsync();
    }

    private async Task HandleSubmit() => await OnValidSubmit.InvokeAsync();
}
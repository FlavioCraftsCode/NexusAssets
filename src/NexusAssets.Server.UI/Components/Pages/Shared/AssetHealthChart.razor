<div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col items-center justify-center">
    <h3 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-4">Status de Ocupação</h3>
    
    <div class="relative w-40 h-40">
        <svg class="w-full h-full" viewBox="0 0 36 36">
            <path class="text-slate-100" stroke-width="3" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
            <path class="text-indigo-600" stroke-width="3" stroke-dasharray="@Percentage, 100" stroke-linecap="round" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
        </svg>
        <div class="absolute inset-0 flex items-center justify-center flex-col">
            <span class="text-3xl font-black text-slate-900">@Percentage%</span>
            <span class="text-[10px] text-slate-400 font-bold uppercase">Em Uso</span>
        </div>
    </div>
    
    <div class="mt-4 grid grid-cols-2 gap-4 w-full">
        <div class="text-center border-r border-slate-100">
            <p class="text-xs text-slate-400 font-bold uppercase">Ativos</p>
            <p class="font-black text-slate-900">@TotalCount</p>
        </div>
        <div class="text-center">
            <p class="text-xs text-slate-400 font-bold uppercase">Valor</p>
            <p class="font-black text-indigo-600">@TotalValue.ToString("C0")</p>
        </div>
    </div>
</div>

@code {
    [Parameter] public int Percentage { get; set; } = 75; 
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public decimal TotalValue { get; set; }
}